# Backend Port Configuration
PORT=4002

# Database Configuration (PostgreSQL + PostGIS)
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=yacheyka

# MinIO / S3 Configuration
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=yacheyka-gallery
# Public URL for the browser to load uploaded files (inside Docker: http://localhost:9000)
MINIO_PUBLIC_URL=http://localhost:9000

# Telegram Auth
# Bot token from @BotFather. Required for verifying Mini App initData and Login Widget payloads.
TELEGRAM_BOT_TOKEN=replace_with_bot_token
# Separate random server secret for signed app sessions. Use a long random value in production.
AUTH_SESSION_SECRET=replace_with_long_random_secret
AUTH_SESSION_TTL_SECONDS=604800
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Only this Telegram account can open and call admin endpoints.
ADMIN_TELEGRAM_ID=1859857121
ADMIN_TELEGRAM_USERNAME=nick_luzhkov

# Frontend uses this to render the Telegram Login Widget outside the Mini App.
VITE_TELEGRAM_BOT_USERNAME=replace_with_bot_username_without_at
