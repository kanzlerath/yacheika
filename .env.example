# Backend Port Configuration
PORT=4002

# Database Configuration (PostgreSQL + PostGIS)
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=yacheyka

# MinIO / S3 Configuration
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=yacheyka-gallery
# Public URL for the browser to load uploaded files (inside Docker: http://localhost:9000)
MINIO_PUBLIC_URL=http://localhost:9000



# Telegram Auth
# Bot token from @BotFather. Keep real tokens only in the server .env.
TELEGRAM_BOT_TOKEN=replace_with_bot_token
# Telegram OAuth / OIDC app settings from @BotFather.
TELEGRAM_CLIENT_ID=replace_with_numeric_client_id
TELEGRAM_CLIENT_SECRET=replace_with_client_secret
TELEGRAM_REDIRECT_URI=https://thescope.ru/api/auth/telegram/callback
# Separate random server secret for signed app sessions. Use a long random value in production.
AUTH_SESSION_SECRET=replace_with_long_random_secret
AUTH_SESSION_TTL_SECONDS=604800
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Initial owner account for /admin. Store only a bcrypt hash, never plaintext password.
ADMIN_OWNER_EMAIL=luzhkoff00@gmail.com
ADMIN_OWNER_PASSWORD_HASH=replace_with_bcrypt_hash
ADMIN_SESSION_SECRET=replace_with_long_random_secret
ADMIN_SESSION_TTL_SECONDS=604800

# Public production domain used for auth redirects and secure cookies.
DOMAIN_NAME=thescope.ru
