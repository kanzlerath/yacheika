// === API ROUTES ===

// 1. Venues (Get all and CRUD)
app.get("/api/venues", (req, res) => {
  res.json(venues);
});

app.post("/api/venues", (req, res) => {
  const data = req.body;
  
  if (!data.name || !data.category) {
    return res.status(400).json({ error: "Missing required fields (name, category)" });
  }

  const existingIndex = venues.findIndex(v => v.id === data.id);
  const now = new Date().toISOString();

  let venue: Venue;

  if (existingIndex > -1) {
    // Update
    venue = {
      ...venues[existingIndex],
      ...data,
      updatedAt: now
    };
    venues[existingIndex] = venue;
  } else {
    // Create new
    const id = data.id || `v-${Math.random().toString(36).substr(2, 9)}`;
    const slug = data.slug || data.name.toLowerCase().replace(/[^a-z0-9]+/g, "-");
    
    venue = {
      id,
      slug,
      name: data.name,
      category: data.category,
      shortDescription: data.shortDescription || "",
      fullDescription: data.fullDescription || "",
      address: data.address || "",
      latitude: Number(data.latitude) || 55.0302,
      longitude: Number(data.longitude) || 82.9204,
      workingHours: data.workingHours || "Ежедневно с 18:00",
      contacts: data.contacts || {},
      gallery: data.gallery && data.gallery.length ? data.gallery : [PHOTO_PRESETS[0]],
      tags: data.tags || [],
      status: data.status || "published",
      premiumConfig: {
        premiumActive: data.premiumConfig?.premiumActive || false,
        premiumTheme: data.premiumConfig?.premiumTheme || "crimson-glow",
        customColors: data.premiumConfig?.customColors || {
          primary: "#111",
          accent: "#f43f5e",
          glowColor: "rgba(244, 63, 94, 0.4)"
        },
        heroImage: data.premiumConfig?.heroImage || (data.gallery && data.gallery[0]),
        moodBlock: data.premiumConfig?.moodBlock || "",
        featuredDrinks: data.premiumConfig?.featuredDrinks || [],
        ctaText: data.premiumConfig?.ctaText || "",
        ctaUrl: data.premiumConfig?.ctaUrl || ""
      },
      createdAt: now,
      updatedAt: now,
      likesCount: 0,
      notMyPlaceCount: 0,
      vibeRatings: {}
    };
    venues.push(venue);
  }

  // Push to analytics log
  analytics.unshift({
    id: `an-${Date.now()}`,
    eventType: "open_venue", // using core event
    venueId: venue.id,
    timestamp: now,
    metadata: { action: "venue_crud", name: venue.name }
  });

  res.json(venue);
});

app.delete("/api/venues/:id", (req, res) => {
  const { id } = req.params;
  venues = venues.filter(v => v.id !== id);
  res.json({ success: true });
});

// 2. Collections APIs
app.get("/api/collections", (req, res) => {
  res.json(collections);
});

app.post("/api/collections", (req, res) => {
  const data = req.body;
  if (!data.title) {
    return res.status(400).json({ error: "Missing collection title" });
  }

  const existingIndex = collections.findIndex(c => c.id === data.id);
  const now = new Date().toISOString();

  let collection: Collection;

  if (existingIndex > -1) {
    collection = {
      ...collections[existingIndex],
      ...data
    };
    collections[existingIndex] = collection;
  } else {
    const id = data.id || `c-${Math.random().toString(36).substr(2, 9)}`;
    collection = {
      id,
      title: data.title,
      description: data.description || "",
      cover: data.cover || PHOTO_PRESETS[3],
      venueIds: data.venueIds || [],
      publishedAt: now
    };
    collections.push(collection);
  }

  res.json(collection);
});

app.delete("/api/collections/:id", (req, res) => {
  const { id } = req.params;
  collections = collections.filter(c => c.id !== id);
  res.json({ success: true });
});

// 3. Events APIs
app.get("/api/events", (req, res) => {
  res.json(events);
});

app.post("/api/events", (req, res) => {
  const data = req.body;
  if (!data.title || !data.venueId) {
    return res.status(400).json({ error: "Missing title or venueId for event" });
  }

  const existingIndex = events.findIndex(e => e.id === data.id);
  let eventItem: VenueEvent;

  if (existingIndex > -1) {
    eventItem = {
      ...events[existingIndex],
      ...data
    };
    events[existingIndex] = eventItem;
  } else {
    const id = data.id || `e-${Math.random().toString(36).substr(2, 9)}`;
    eventItem = {
      id,
      venueId: data.venueId,
      title: data.title,
      description: data.description || "",
      date: data.date || new Date().toISOString().split("T")[0],
      time: data.time || "20:00",
      coverImage: data.coverImage || PHOTO_PRESETS[1]
    };
    events.push(eventItem);
  }

  res.json(eventItem);
});

app.delete("/api/events/:id", (req, res) => {
  const { id } = req.params;
  events = events.filter(e => e.id !== id);
  res.json({ success: true });
});

// 4. Reactions & User logic
// Toggle reaction / like / not_my_place for venue
app.post("/api/venues/:id/react", (req, res) => {
  const venueId = req.params.id;
  const { userId, type, vibeTag } = req.body; // type: 'like' | 'not_my_place' | 'vibe_tag'

  if (!userId) {
    return res.status(400).json({ error: "Unauthorized: Telegram userId required" });
  }

  const venue = venues.find(v => v.id === venueId);
  if (!venue) {
    return res.status(404).json({ error: "Venue not found" });
  }

  // Check if this user already reacts using this type
  // Note: Only one reaction of a specific type or max one absolute reaction except multiple unique vibe tags
  const existingReact = reactions.find(r => r.userId === userId && r.venueId === venueId && r.type === type && (type !== "vibe_tag" || r.vibeTag === vibeTag));

  const now = new Date().toISOString();

  if (existingReact) {
    // Deselect (Toggle off)
    reactions = reactions.filter(r => r.id !== existingReact.id);
    
    // Decrement counters
    if (type === "like") {
      venue.likesCount = Math.max(0, venue.likesCount - 1);
    } else if (type === "not_my_place") {
      venue.notMyPlaceCount = Math.max(0, venue.notMyPlaceCount - 1);
    } else if (type === "vibe_tag" && vibeTag) {
      if (venue.vibeRatings[vibeTag]) {
        venue.vibeRatings[vibeTag] = Math.max(0, venue.vibeRatings[vibeTag] - 1);
        if (venue.vibeRatings[vibeTag] === 0) {
          delete venue.vibeRatings[vibeTag];
        }
      }
    }

    analytics.unshift({
      id: `an-${Date.now()}`,
      eventType: type === "like" ? "like" : "reaction",
      venueId,
      userId,
      timestamp: now,
      metadata: { action: "remove_reaction", type, vibeTag }
    });

    return res.json({ removed: true, venue });
  }

  // Create new reaction
  // If user likes, they cannot 'not_my_place' simultaneously, let's remove opposite reaction to keep records simple!
  if (type === "like") {
    const opp = reactions.find(r => r.userId === userId && r.venueId === venueId && r.type === "not_my_place");
    if (opp) {
      reactions = reactions.filter(r => r.id !== opp.id);
      venue.notMyPlaceCount = Math.max(0, venue.notMyPlaceCount - 1);
    }
  } else if (type === "not_my_place") {
    const opp = reactions.find(r => r.userId === userId && r.venueId === venueId && r.type === "like");
    if (opp) {
      reactions = reactions.filter(r => r.id !== opp.id);
      venue.likesCount = Math.max(0, venue.likesCount - 1);
    }
  }

  const reaction: Reaction = {
    id: `r-${Math.random().toString(36).substr(2, 9)}`,
    userId,
    venueId,
    type,
    vibeTag,
    createdAt: now
  };
  reactions.push(reaction);

  // Increment counters
  if (type === "like") {
    venue.likesCount += 1;
  } else if (type === "not_my_place") {
    venue.notMyPlaceCount += 1;
  } else if (type === "vibe_tag" && vibeTag) {
    if (!venue.vibeRatings[vibeTag]) {
      venue.vibeRatings[vibeTag] = 0;
    }
    venue.vibeRatings[vibeTag] += 1;
  }

  analytics.unshift({
    id: `an-${Date.now()}`,
    eventType: type === "like" ? "like" : "reaction",
    venueId,
    userId,
    timestamp: now,
    metadata: { action: "add_reaction", type, vibeTag }
  });

  res.json({ added: true, venue });
});

// Helper endpoint for active reactions list of user
app.get("/api/users/:userId/reactions", (req, res) => {
  const { userId } = req.params;
  const userReacts = reactions.filter(r => r.userId === userId);
  res.json(userReacts);
});

// 5. Analytics (Post action logging and get feed for dashboard)
app.post("/api/analytics", (req, res) => {
  const { eventType, venueId, userId, metadata } = req.body;
  const newEvent: AnalyticsEvent = {
    id: `an-${Date.now()}`,
    eventType,
    venueId,
    userId,
    timestamp: new Date().toISOString(),
    metadata
  };
  analytics.unshift(newEvent);
  
  if (analytics.length > 300) {
    analytics = analytics.slice(0, 300); // capped limit
  }

  res.json({ success: true });
});

app.get("/api/analytics", (req, res) => {
  res.json(analytics);
});

// === SERVER CONFIG & PORT INGRESS ===

// Integrate Vite middleware for static assets + Hot Reload proxy routing in sandbox
const startServer = async () => {
  if (process.env.NODE_ENV !== "production") {
    const vite = await createViteServer({
      server: { middlewareMode: true },
      appType: "spa",
    });
    app.use(vite.middlewares);
  } else {
    const distPath = path.join(process.cwd(), "dist");
    app.use(express.static(distPath));
    app.get("*", (req, res) => {
      res.sendFile(path.join(distPath, "index.html"));
    });
  }

  app.listen(PORT, "0.0.0.0", () => {
    console.log(`[Ячейка Server] Backend initialized on http://0.0.0.0:${PORT}`);
  });
};

startServer().catch((err) => {
  console.error("Critical: Failed to boot Express+Vite development server integration:", err);
});
